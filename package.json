{
  "name": "pi-plugins",
  "version": "0.1.0",
  "description": "pi package with shared skills, extensions, prompt templates, and themes.",
  "private": true,
  "keywords": ["pi-package", "pi", "skills", "extensions", "prompts", "themes"],
  "license": "MIT",
  "pi": {
    "skills": ["./skills"],
    "extensions": ["./extensions"],
    "prompts": ["./prompts"],
    "themes": ["./themes"]
  },
  "scripts": {
    "validate": "node scripts/validate-package.mjs",
    "validate:skills": "node scripts/validate-package.mjs --skills-only"
  },
  "dependencies": {
    "puppeteer-core": "^23.11.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "typebox": "*"
  }
}
